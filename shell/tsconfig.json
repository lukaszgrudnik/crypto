{
  "compilerOptions": {
    // Determines how modules are resolved.
    // 'nodenext' allows using both CommonJS and ES modules,
    // supporting Node.js-style resolution with .js, .ts, .mts, .cts extensions.
    "moduleResolution": "nodenext",

    // Specifies the JSX code generation mode.
    // 'react' generates code compatible with older React (pre-17), using React.createElement.
    // Use 'react-jsx' or 'react-jsxdev' for React 17+ with the new JSX transform.
    "jsx": "react-jsx",

    // Specifies the target ECMAScript version for the compiled code.
    // ESNext allows using the latest JavaScript features like optional chaining, nullish coalescing, etc.
    "target": "ESNext",

    // Specifies the module code generation method.
    // ESNext supports the latest ES module syntax (import/export).
    "module": "NodeNext",

    // Enables all strict type-checking options.
    // Helps catch potential bugs by enforcing type safety.
    "strict": true,

    // Allows default imports from modules with no default export.
    // Ensures compatibility with CommonJS modules.
    "esModuleInterop": true,

    // Skips type checking of declaration files (*.d.ts).
    // Speeds up builds by trusting external types.
    "skipLibCheck": true
  }
}
